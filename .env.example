# Copy to .env.local for local runs. Per-environment values for CI/EAS builds
# are set via EAS build profiles (eas.json) and EAS secrets instead.

# One of: development | testing | staging | production
APP_ENV=development

# EAS project id (run `eas init` to generate, or paste from expo.dev).
EAS_PROJECT_ID=

# Per-environment API base URL — read at runtime via expo-constants `extra`.
# EXPO_PUBLIC_API_URL=https://api.dev.example.com
